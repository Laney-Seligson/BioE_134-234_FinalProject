{"geneId":"11816","symbol":"Apoe","description":"apolipoprotein E","taxId":"10090","taxname":"Mus musculus","type":"PROTEIN_CODING","orientation":"minus","commonName":"house mouse","chromosomes":["7"],"nomenclatureAuthority":{"authority":"MGI","identifier":"MGI:88057"},"swissProtAccessions":["P08226"],"ensemblGeneIds":["ENSMUSG00000002985"],"synonyms":["Apo-E"],"annotations":[{"assemblyAccession":"GCF_000001635.27","assemblyName":"GRCm39","annotationName":"GCF_000001635.27-RS_2024_02","annotationReleaseDate":"2024-02-01","genomicLocations":[{"genomicAccessionVersion":"NC_000073.7","sequenceName":"7","genomicRange":{"begin":"19430169","end":"19434326","orientation":"minus"}}]}],"transcriptCount":5,"proteinCount":5,"transcriptTypeCounts":[{"type":"PROTEIN_CODING","count":4},{"type":"PROTEIN_CODING_MODEL","count":1}],"geneGroups":[{"id":"348","method":"NCBI Ortholog"}],"summary":[{"description":"This gene encodes a member of the apolipoprotein A1/A4/E family of proteins. This protein is involved in the transport of lipoproteins in the blood. It binds to a specific liver and peripheral cell receptor, and is essential for the normal catabolism of triglyceride-rich lipoprotein constituents. Homozygous knockout mice for this gene accumulate high levels of cholesterol in the blood and develop atherosclerosis. Different alleles of this gene have been associated with either increased risk or a protective effect for Alzheimer's disease in human patients. This gene maps to chromosome 7 in a cluster with the related apolipoprotein C1, C2 and C4 genes. [provided by RefSeq, Apr 2015]"}],"geneOntology":{"assignedBy":"MGI","molecularFunctions":[{"name":"amyloid-beta binding","goId":"GO:0001540","evidenceCode":"IEA","qualifier":"enables"},{"name":"amyloid-beta binding","goId":"GO:0001540","evidenceCode":"ISO","qualifier":"enables"},{"name":"amyloid-beta binding","goId":"GO:0001540","evidenceCode":"ISS","qualifier":"enables"},{"name":"antioxidant activity","goId":"GO:0016209","evidenc