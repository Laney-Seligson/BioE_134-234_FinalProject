{
  "id": "org.bioe134-234.function.cloning.lab_sheet.v1",
  "name": "Lab Sheet Generator",
  "description": "Renders a bench-ready plain-text lab sheet from a structured construction file, matching the LabPlanner format. Output is organized into lettered sections (A: PCR, A: Assemble, A: Transform) with samples tables, source locations, reaction volumes, and notes.",
  "type": "function",
  "seq_params": [],
  "keywords": [
    "lab sheet",
    "bench protocol",
    "PCR",
    "GoldenGate",
    "Gibson",
    "transformation",
    "cloning",
    "reagents",
    "construction file"
  ],
  "date_created": null,
  "date_last_modified": null,
  "inputs": [
    {
      "name": "construction_record",
      "type": "object",
      "description": "The structured construction file dict from create_construction_file (the 'structured_construction_file' key). Must contain construct_name, assembly_strategy, and operations."
    },
    {
      "name": "thread",
      "type": "string",
      "description": "Single-letter thread identifier used as section prefix (e.g. 'A' produces 'A: PCR', 'A1', 'A2'). Default 'A'."
    },
    {
      "name": "include_notes",
      "type": "boolean",
      "description": "If true, appends notes from the construction file at the bottom of the lab sheet. Default true."
    }
  ],
  "outputs": [
    {
      "type": "object",
      "description": "Bench-ready lab sheet as plain text in LabPlanner format.",
      "properties": {
        "construct_name": { "type": "string" },
        "assembly_strategy": { "type": "string" },
        "lab_sheet_text": { "type": "string", "description": "Full plain-text bench protocol in LabPlanner format." },
        "step_count": { "type": "integer" }
      }
    }
  ],
  "examples": [
    {
      "input": {
        "construction_record": {
          "construct_name": "pTarget-cscB1",
          "assembly_strategy": "GoldenGate",
          "parts": [],
          "operations": [
            {
              "step_number": 1,
              "step_type": "PCR",
              "inputs": ["cscB1", "pTargRev", "pTargetF"],
              "parameters": { "forward_primer": "cscB1", "reverse_primer": "pTargRev", "template": "pTargetF" },
              "output": "ipcr1",
              "description": ""
            },
            {
              "step_number": 2,
              "step_type": "GoldenGate",
              "inputs": ["vec_pcr", "ipcr1"],
              "parameters": { "enzyme": "BsaI" },
              "output": "pTarget-cscB1",
              "description": ""
            },
            {
              "step_number": 3,
              "step_type": "Transform",
              "inputs": ["pTarget-cscB1"],
              "parameters": { "cells": "Mach1", "selection": "Spec", "temperature_c": 37 },
              "output": "pTarget-cscB1_e",
              "description": ""
            }
          ],
          "notes": ""
        },
        "thread": "A"
      },
      "output": {
        "construct_name": "pTarget-cscB1",
        "assembly_strategy": "GoldenGate",
        "step_count": 5
      }
    }
  ],
  "execution_details": {
    "language": "Python",
    "source": "modules/crispr_tools/tools/lab_sheet.py",
    "initialization": "initiate",
    "execution": "run",
    "disposal": null,
    "mcp_name": "generate_lab_sheet"
  }
}
