{
  "id": "org.bioe234.function.create_construction_file.v2",
  "name": "Create_Construction_File",
  "description": "Generate either (1) a full DNA cloning construction file from sequences, (2) a structured paper information resource, or (3) a shorthand construction workflow derived from a paper. Always choose the correct input_mode before calling this tool.",
  "type": "function",
  "keywords": [
    "cloning",
    "DNA assembly",
    "GoldenGate",
    "Gibson",
    "CRISPR",
    "construction file",
    "paper extraction",
    "workflow abstraction",
    "synthetic biology"
  ],

  "inputs": [
    {
      "name": "input_mode",
      "type": "string",
      "description": "Select mode: 'sequence_build', 'paper_info', or 'paper_shorthand'. This determines required fields and behavior.",
      "enum": ["sequence_build", "paper_info", "paper_shorthand"]
    },

    {
      "name": "construct_name",
      "type": "string",
      "description": "Name of final construct (required for sequence_build)."
    },
    {
      "name": "assembly_strategy",
      "type": "string",
      "description": "Assembly strategy for sequence_build. Options: GoldenGate, Gibson, DirectSynthesis."
    },
    {
      "name": "backbone_name",
      "type": "string",
      "description": "Backbone plasmid name (sequence_build only)."
    },
    {
      "name": "backbone_sequence",
      "type": "string",
      "description": "Backbone DNA sequence (sequence_build only). Must be valid DNA."
    },
    {
      "name": "insert_name",
      "type": "string",
      "description": "Insert name (sequence_build only)."
    },
    {
      "name": "insert_sequence",
      "type": "string",
      "description": "Insert DNA sequence (sequence_build only). Must be valid DNA."
    },
    {
      "name": "insert_forward_primer_name",
      "type": "string",
      "description": "Forward primer name for insert (GoldenGate/Gibson only)."
    },
    {
      "name": "insert_forward_primer_sequence",
      "type": "string",
      "description": "Forward primer sequence (GoldenGate/Gibson only)."
    },
    {
      "name": "insert_reverse_primer_name",
      "type": "string",
      "description": "Reverse primer name for insert."
    },
    {
      "name": "insert_reverse_primer_sequence",
      "type": "string",
      "description": "Reverse primer sequence."
    },
    {
      "name": "vector_forward_primer_name",
      "type": "string",
      "description": "Vector forward primer name."
    },
    {
      "name": "vector_forward_primer_sequence",
      "type": "string",
      "description": "Vector forward primer sequence."
    },
    {
      "name": "vector_reverse_primer_name",
      "type": "string",
      "description": "Vector reverse primer name."
    },
    {
      "name": "vector_reverse_primer_sequence",
      "type": "string",
      "description": "Vector reverse primer sequence."
    },
    {
      "name": "enzyme",
      "type": "string",
      "description": "Assembly enzyme (required for GoldenGate)."
    },
    {
      "name": "cell_strain",
      "type": "string",
      "description": "Transformation host strain."
    },
    {
      "name": "selection",
      "type": "string",
      "description": "Selection marker (e.g. Kan, Amp)."
    },
    {
      "name": "temperature_c",
      "type": "integer",
      "description": "Transformation temperature."
    },


    {
      "name": "paper_id",
      "type": "string",
      "description": "Unique identifier for the paper (required for paper modes)."
    },
    {
      "name": "title",
      "type": "string",
      "description": "Paper title."
    },
    {
      "name": "source_pdf",
      "type": "string",
      "description": "Source PDF filename or resource."
    },
    {
      "name": "organism",
      "type": "string",
      "description": "Organism used in the paper."
    },
    {
      "name": "system",
      "type": "string",
      "description": "Editing or cloning system (e.g. CRISPR-Cas9)."
    },
    {
      "name": "targets",
      "type": "array",
      "items": { "type": "string" },
      "description": "Target genes or loci."
    },
    {
      "name": "vectors",
      "type": "array",
      "items": { "type": "string" },
      "description": "Plasmids or constructs used."
    },
    {
      "name": "enzymes",
      "type": "array",
      "items": { "type": "string" },
      "description": "Relevant enzymes."
    },
    {
      "name": "assembly_method",
      "type": "string",
      "description": "Assembly method (Gateway, GoldenGate, Gibson, DirectSynthesis)."
    },
    {
      "name": "delivery_method",
      "type": "array",
      "items": { "type": "string" },
      "description": "Transformation or delivery methods."
    },
    {
      "name": "validation_methods",
      "type": "array",
      "items": { "type": "string" },
      "description": "Validation techniques used."
    },
    {
      "name": "key_constraints",
      "type": "array",
      "items": { "type": "string" },
      "description": "Important limitations (e.g. missing sequences)."
    },
    {
      "name": "paper_notes",
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional notes about the paper."
    }
  ],

  "outputs": [
    {
      "type": "object",
      "description": "Output depends on input_mode: sequence_build returns a construction file, paper_info returns structured metadata, paper_shorthand returns shorthand workflow."
    }
  ]
}